# ================================================
# .gitignore — максимальная защита iFile 2026
# index.php запрещён к просмотру навсегда
# ================================================

# === Главный файл, который прячем ===
index.php

# Конфиги и пароли
.env
config.php
settings.php
database.php
*.env*

# Логи, кэш, временные файлы
*.log
logs/
cache/
tmp/
temp/

# Зависимости
vendor/
node_modules/

# IDE и мусор
.vscode/
.idea/
.DS_Store
Thumbs.db
*.bak
*.backup

# ================================================
# ПУБЛИЧНЫЕ файлы (видны всем):
# ================================================
!README.md
!demo.index.php
!*.example
!*.example.php
!.gitignore
